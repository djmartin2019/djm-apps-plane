# VPS production environment (root)
# Copy to .env.vps, fill in secrets, then sync with: ./deploy/env-sync.sh
#
# Plane binds to a high host port; Apache/nginx on the VPS terminates TLS and
# reverse-proxies to LISTEN_HTTP_PORT (see deploy/apache-plane.conf.example).

# Database Settings — use strong passwords in production
POSTGRES_USER="plane"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
POSTGRES_DB="plane"
PGDATA="/var/lib/postgresql/data"

# Redis Settings
REDIS_HOST="plane-redis"
REDIS_PORT="6379"

# RabbitMQ Settings — use strong passwords in production
RABBITMQ_HOST="plane-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="plane"
RABBITMQ_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
RABBITMQ_VHOST="plane"

# Host port for Plane's Caddy proxy (must be free; Apache uses 80/443)
LISTEN_HTTP_PORT=8090
LISTEN_HTTPS_PORT=8443

# MinIO (internal Docker network)
AWS_REGION=""
AWS_ACCESS_KEY_ID="CHANGE_ME_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="CHANGE_ME_SECRET_KEY"
AWS_S3_ENDPOINT_URL="http://plane-minio:9000"
AWS_S3_BUCKET_NAME="uploads"
FILE_SIZE_LIMIT=5242880

USE_MINIO=1

# TLS is handled by Apache — leave CERT_EMAIL empty; Caddy listens on :80 inside the container
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TRUSTED_PROXIES=0.0.0.0/0
SITE_ADDRESS=:80
CERT_EMAIL=
CERT_ACME_DNS=

MINIO_ENDPOINT_SSL=0
API_KEY_RATE_LIMIT="60/minute"
